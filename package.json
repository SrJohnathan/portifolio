{
  "name": "portfolio",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "adaptive dev",
    "build": "adaptive build",
    "build:node": "adaptive build --preset node",
    "build:netlify": "adaptive build --preset netlify && node ./scripts/netlify-postbuild.mjs",
    "build:vercel": "adaptive build --preset vercel",
    "preview:node": "npm run build:node && adaptive preview --preset node",
    "preview:netlify": "npm run build:netlify && adaptive preview --preset netlify",
    "preview:vercel": "npm run build:vercel && adaptive preview --preset vercel",
    "start": "adaptive start",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@adaptivejs/ft": "^0.1.4",
    "@adaptivejs/ui": "^0.1.4",
    "@adaptivejs/web": "^0.1.4"
  },
  "devDependencies": {
    "@adaptivejs/cli": "^0.1.4",
    "@adaptivejs/static": "^0.1.4",
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.8.2"
  }
}
